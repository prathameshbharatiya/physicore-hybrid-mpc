rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.email == "prathameshshirbhate8anpc@gmail.com" &&
        request.auth.token.email_verified == true;
    }

    match /allowed_users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || request.auth.token.email == resource.data.email);
      allow create: if isAuthenticated() && (isAdmin() || isOwner(userId));
      allow update: if isAuthenticated() && (isAdmin() || isOwner(userId));
      allow delete: if isAdmin();
    }

    match /test/connection { allow read: if true; }

    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /{document=**} { allow read, write: if false; }
  }
}
